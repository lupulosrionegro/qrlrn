# Neon PostgreSQL — copiar desde el dashboard de Neon
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# NextAuth — generá un secret con: openssl rand -base64 32
NEXTAUTH_SECRET=tu_secret_aleatorio_aqui
NEXTAUTH_URL=https://qr.lupulosrionegro.com.ar

# Google OAuth — desde console.cloud.google.com
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxx

# Vercel Blob — se genera automáticamente al conectar Blob en Vercel
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx

# Email del administrador (solo este email puede acceder al panel admin)
ADMIN_EMAIL=lupulosrionegro@gmail.com
